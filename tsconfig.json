{
    "compilerOptions": {
        "target": "ES2024",
        "module": "CommonJS",
        "moduleResolution": "node10",
        "ignoreDeprecations": "6.0",
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": false,
        "forceConsistentCasingInFileNames": true,
        "declaration": true,
        "sourceMap": true,
        "erasableSyntaxOnly": true
    },
    "include": ["app.ts", "lib/**/*.ts"],
    "exclude": ["node_modules", "dist", "test"]
}
