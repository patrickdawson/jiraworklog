{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": ["ES2022"],
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "outDir": "dist",
        "rootDir": ".",
        "skipLibCheck": true
    },
    "include": ["app.ts", "lib/**/*.ts", "test/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
