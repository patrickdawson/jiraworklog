{
    "name": "jirabooking",
    "version": "1.0.0",
    "description": "",
    "type": "module",
    "main": "out/main/main.js",
    "scripts": {
        "dev": "node --import tsx/esm --no-warnings app.ts",
        "dev:app": "electron-vite dev",
        "start": "tsc && node dist/app.js",
        "build": "tsc",
        "build:electron": "electron-vite build",
        "dist": "npm run build:electron && electron-builder",
        "preview:app": "electron-vite preview",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:dev": "vitest",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prettier": "prettier --check **/*.{ts,tsx,js,json}",
        "prettier:write": "prettier --write **/*.{ts,tsx,js,json}"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@inquirer/prompts": "8.3.2",
        "axios": "1.14.0",
        "conf": "10.1.2",
        "dayjs": "1.11.20",
        "dotenv": "17.3.1",
        "fuzzy": "0.1.3",
        "lodash-es": "4.18.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "table": "6.8.1"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@types/lodash-es": "4.17.12",
        "@types/node": "22.19.17",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "4.7.0",
        "electron": "41.1.1",
        "electron-builder": "26.8.1",
        "electron-vite": "5.0.0",
        "eslint": "10.0.0",
        "eslint-config-prettier": "10.1.8",
        "globals": "17.3.0",
        "nock": "13.5.6",
        "prettier": "3.8.1",
        "tsx": "4.21.0",
        "typescript": "6.0.2",
        "typescript-eslint": "8.58.0",
        "vite": "6.4.1",
        "vitest": "4.1.2"
    },
    "build": {
        "appId": "com.jiraworklog.app",
        "productName": "Jira Worklog",
        "icon": "build/icon.png",
        "directories": {
            "output": "release"
        },
        "files": [
            "out/**",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "build/icon.png",
                "to": "icon.png"
            }
        ],
        "win": {
            "target": [
                "nsis"
            ]
        }
    }
}
