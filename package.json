{
    "name": "jirabooking",
    "version": "1.0.0",
    "description": "",
    "type": "module",
    "main": "out/main/main.js",
    "scripts": {
        "dev": "node --import tsx/esm --no-warnings app.ts",
        "dev:app": "electron-vite dev",
        "start": "tsc && node dist/app.js",
        "build": "tsc",
        "build:electron": "electron-vite build",
        "dist": "npm run build:electron && electron-builder",
        "preview:app": "electron-vite preview",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:dev": "vitest",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "prettier": "prettier --check **/*.{ts,tsx,js,json}",
        "prettier:write": "prettier --write **/*.{ts,tsx,js,json}"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@inquirer/prompts": "8.5.0",
        "axios": "1.16.1",
        "conf": "15.1.0",
        "dayjs": "1.11.21",
        "dotenv": "17.4.2",
        "fuzzy": "0.1.3",
        "lodash-es": "4.18.1",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "table": "6.9.0"
    },
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@types/lodash-es": "4.17.12",
        "@types/node": "25.9.1",
        "@types/react": "19.2.15",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "5.2.0",
        "electron": "42.2.0",
        "electron-builder": "26.8.1",
        "electron-vite": "5.0.0",
        "eslint": "10.4.0",
        "eslint-config-prettier": "10.1.8",
        "globals": "17.6.0",
        "nock": "14.0.15",
        "prettier": "3.8.3",
        "tsx": "4.22.3",
        "typescript": "6.0.3",
        "typescript-eslint": "8.60.0",
        "vite": "7.3.3",
        "vitest": "4.1.7"
    },
    "build": {
        "appId": "com.jiraworklog.app",
        "productName": "Jira Worklog",
        "icon": "build/icon.png",
        "directories": {
            "output": "release"
        },
        "files": [
            "out/**",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "build/icon.png",
                "to": "icon.png"
            }
        ],
        "win": {
            "target": [
                "nsis"
            ]
        }
    }
}
